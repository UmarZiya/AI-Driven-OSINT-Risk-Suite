# ─── Server ───────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# ─── Database ─────────────────────────────────────────────────────────────────
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/osint_risk_suite

# ─── Auth (for your teammates' auth module) ───────────────────────────────────
JWT_SECRET=replace_with_a_long_random_secret_here
JWT_EXPIRES_IN=7d

# ──────────────────────────────────────────────────────────────────────────────
# ALL API KEYS BELOW ARE FREE — NO CREDIT CARD REQUIRED
# ──────────────────────────────────────────────────────────────────────────────

# ─── Shodan (FREE account) ────────────────────────────────────────────────────
# Register at: https://account.shodan.io
# Free tier: 100 query credits/month, host lookups included
# After registering, find your key at: https://account.shodan.io
# NOTE: The built-in port scanner works WITHOUT this key — Shodan just adds extra info
SHODAN_API_KEY=your_free_shodan_key_here

# ─── Censys (FREE account) ────────────────────────────────────────────────────
# Register at: https://accounts.censys.io/register
# Free tier: 250 queries/month
# After registering: https://search.censys.io/account → API Access
# OPTIONAL — the system works without it
CENSYS_API_ID=your_free_censys_api_id
CENSYS_API_SECRET=your_free_censys_secret

# ─── RapidAPI (FREE account) — for BreachDirectory ───────────────────────────
# Register at: https://rapidapi.com (completely free)
# Then subscribe (free) to: https://rapidapi.com/rohan-patra/api/breachdirectory
# Free tier: 50 breach lookups/day
# OPTIONAL — the system works without it (uses LeakCheck + EmailRep as fallback)
RAPIDAPI_KEY=your_free_rapidapi_key_here

# ──────────────────────────────────────────────────────────────────────────────
# WHAT WORKS WITH ZERO API KEYS (truly zero setup):
#   ✅ Port scanning      — uses Node's built-in net module
#   ✅ DNS enumeration    — uses Node's built-in dns module
#   ✅ WHOIS lookup       — whois-json library, no key
#   ✅ EXIF extraction    — exifr library, no key
#   ✅ Social footprint   — HTTP checks, no key
#   ✅ NLP threat detect  — pattern matching, no key
#   ✅ EmailRep.io        — free, no key (1000 req/day)
#   ✅ LeakCheck.io       — free public endpoint, no key
#   ✅ PwnedPasswords     — k-anonymity endpoint, always free
# ──────────────────────────────────────────────────────────────────────────────
